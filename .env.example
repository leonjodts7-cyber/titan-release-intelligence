# TITAN Release Intelligence OS
# Copy to .env.local: cp .env.example .env.local

# === REQUIRED for production ===
NEXT_PUBLIC_SUPABASE_URL=          # Supabase project URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=     # Supabase anon/public key
SUPABASE_SERVICE_ROLE_KEY=         # Server-side only — never expose to client

# === REQUIRED for production cron ===
CRON_SECRET=                       # Bearer token for /api/cron/scan

# === OPTIONAL: AI scoring ===
OPENAI_API_KEY=                    # GPT-4o-mini scoring (rule-based fallback without)

# === OPTIONAL: Notifications ===
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
RESEND_API_KEY=
RESEND_ALERT_EMAIL=                # Email recipient for alerts

# === OPTIONAL: Live source scanning ===
TICKETMASTER_API_KEY=              # Ticketmaster Discovery API
RSS_FEED_URLS=                     # Comma-separated RSS feed URLs
NIKE_API_KEY=                      # Reserved for future Nike API
ADIDAS_API_KEY=                    # Reserved for future Adidas API

# === OPTIONAL: Market & TCG data ===
STOCKX_API_KEY=                    # StockX market data interface
GOAT_API_KEY=                      # GOAT market data interface
TCGPLAYER_API_KEY=                 # TCGplayer pricing API
CARDMARKET_API_KEY=                # CardMarket pricing API
JUSTTCG_API_KEY=                   # JustTCG pricing API
POKEWALLET_API_KEY=                # PokéWallet pricing API
